    HourlyRate,
    JobInvolvement,
    JobLevel,
    JobSatisfaction,
    MonthlyIncome,
    MonthlyRate,
    NumCompaniesWorked,
    PercentSalaryHike,
    PerformanceRating,
    RelationshipSatisfaction,
