    coalesce(b.DistanceFromHome, s.median_distance) as DistanceFromHome,
    coalesce(b.Education, s.median_education) as Education,
    coalesce(b.EnvironmentSatisfaction, s.median_envsat) as EnvironmentSatisfaction,
