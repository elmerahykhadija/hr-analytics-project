select

    -- 🔥 TARGET
    Attrition,
    -- 🔵 NUMÉRIQUES (déjà clean)
    Age,
    DailyRate,
    DistanceFromHome,
    Education,
    EnvironmentSatisfaction,
    HourlyRate,
    JobInvolvement,
